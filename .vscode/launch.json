{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "bunq-api",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": ["src.bunq_api.app:app", "--reload"],
            "python": "${workspaceFolder}/bunq-api/.venv/bin/python",
            "cwd": "${workspaceFolder}/bunq-api",
            "console": "integratedTerminal"
        },
        {
            "name": "bunq-api: current file",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "python": "${workspaceFolder}/bunq-api/.venv/bin/python",
            "cwd": "${workspaceFolder}/bunq-api",
            "console": "integratedTerminal"
        }
    ]
}